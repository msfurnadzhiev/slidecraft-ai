OPENROUTER_MODEL="meta-llama/llama-3.2-3b-instruct:free"
OPENROUTER_API_KEY="<YOUR_OPENROUTER_API_KEY>"

# Gemini (inactive – uncomment to switch back)
# GENAI_MODEL_NAME="gemini-2.0-flash"
# GENAI_API_KEY="<YOUR_GOOGLE_API_KEY>"

# Rate limits (adjust per model tier)
LLM_RPM_LIMIT=30
LLM_TPM_LIMIT=15000

# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

EMBEDDINGS_API_URL="http://localhost:8080/v1"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/slidecraft
