LLM_API_KEY="<your-api-key-here>"

PRESENTATION_AGENT_MODEL_NAME="gemini-3.1-flash-lite-preview"
CONTENT_GENERATOR_AGENT_MODEL_NAME="gemini-3.1-flash-lite-preview"
SLIDE_BUILDER_AGENT_MODEL_NAME="gemini-3.1-flash-lite-preview"
CONTENT_SUMMARIZER_AGENT_MODEL_NAME="gemma-3-27b-it"
