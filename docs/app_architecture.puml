@startuml app_architecture
!theme plain
skinparam packageStyle rectangle

title SlideCraft – App Architecture

rectangle "API Routers" as api #E8F4FD

' ---------------- Left Column: Core Services ----------------
package "Core Services" as core #FFF4E6 {
    package "Ingestion" as injestion {
        [DocumentService] as doc_svc
    }
    
    package "Retrieval" as retriecal {
        [SearchService] as search_svc
        [ContextAssembler] as ctx_assembler
    }
    
    package "Generation (Future)" as generation #FFE6E6 {
        [ContentAnalyzer] as analyzer <<planned>>
        [PresentationPlanner] as planner <<planned>>
        [SlideGenerator] as generator <<planned>>
        [PresentationRenderer] as renderer <<planned>>
    }
}

' ---------------- Right Column: Infrastructure + Ingestion Pipeline ----------------
together {
    package "Infrastructure" as infra #E8F8F0 {
        [FileStorage] as storage
        [Database (CRUD)] as db
    }

    package "Ingestion Pipeline" as ingestion #F5E6FF {
        [PDFLoader]
        [TextChunker]
        [ImageExtractor]
        [TextEmbedder]
        [ImageEmbedder]
    }
}

' ---------------- Layout Hints ----------------
' Ensure right column stays to the right of Core Services
core -[hidden]-> infra

' ---------------- Main Flow ----------------
api --> injestion : upload document
api --> retriecal : search query

doc_svc --> ingestion : process PDF
doc_svc --> db : store chunks/images
doc_svc --> storage : save files

search_svc --> db : vector search
search_svc --> ctx_assembler : raw results

ctx_assembler --> analyzer : <<future>>
analyzer --> planner : <<future>>
planner --> generator : <<future>>
generator --> renderer : <<future>>

ingestion --> db : embeddings
ingestion --> storage : images

@enduml